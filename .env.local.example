# Supabase — copy to `.env.local` and fill in from Supabase Dashboard:
# Project Settings → API → Project URL + anon public key
#
# Do not commit `.env.local` (real keys).

NEXT_PUBLIC_SUPABASE_URL=https://fqmolesnvdknrxfzopio.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-from-supabase-dashboard

# Google Maps — live driver map (Maps JavaScript API)
# Enable "Maps JavaScript API" in Google Cloud Console for this key.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-browser-key
# Server-only key for Distance Matrix ETA + geocoding (Distance Matrix API enabled)
# GOOGLE_MAPS_API_KEY=your-google-maps-server-key

# Server-only — User management (Dashboard → Project Settings → API → service_role)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic — Dolphin AI assistant (server-only)
# ANTHROPIC_API_KEY=your-anthropic-api-key
# ANTHROPIC_MODEL=claude-sonnet-5

# myDATA (ΑΑΔΕ) — ημερήσιο Ζ · server-only, never expose to the browser
# MYDATA_API_KEY=your-subscription-key-from-aade
# MYDATA_USER_ID=your-aade-user-id
# MYDATA_API_URL=https://mydatapi.aade.gr/myDATA/SendInvoices
# Optional sandbox URL when AADE provides test credentials
